<Window x:Class="NEA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:render="clr-namespace:NEA.Rendering"
        Title="NEA - Orbit Trajectories | 3-Body Problem Simulator"
        Background="#260B3B"
        Height="760" Width="1280"
        Loaded="Window_Loaded"
        Unloaded="Window_Unloaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    Margin="10"
                    Background="#ECDCFC"
                    VerticalAlignment="Center">

            <Button x:Name="btnStart" Content="Start" Width="85" Margin="5" Click="btnStart_Click"/>
            <Button x:Name="btnPause" Content="Pause" Width="85" Margin="5" Click="btnPause_Click"/>
            <Button x:Name="btnReset" Content="Reset" Width="85" Margin="5" Click="btnReset_Click"/>
            <Button x:Name="btnNewInstance" Content="New Instance" Width="120" Height="30" Margin="5"
        
             Click="btnNewInstance_Click"/>

            <Button x:Name="btnFullScreen" Content="Full Screen" Width="110" Margin="5" Click="btnFullScreen_Click"/>

            <CheckBox x:Name="chkOrbitLines" Content="Show Orbits" Margin="15,5" IsChecked="True"/>

            <ComboBox x:Name="cmbViewMode" Width="110" Margin="5"
                      SelectionChanged="cmbViewMode_SelectionChanged">
                <ComboBoxItem Content="2D View" IsSelected="True"/>
                <ComboBoxItem Content="3D View"/>
            </ComboBox>

            <TextBlock x:Name="txtTimer"
                       Text="00:00"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="25,5"
                       Foreground="#4A0E6B"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- LEFT PANEL -->
        <ScrollViewer Grid.Row="1" Grid.Column="0"
                      Margin="10"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <!-- Physical Parameters -->
                <Expander Header="Physical Parameters"
                          IsExpanded="True"
                          Background="#E4C9FF">

                    <DataGrid x:Name="dgPhysicalParams"
                              AutoGenerateColumns="False"
                              Height="220"
                              Background="#E4C9FF">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Body" Binding="{Binding BodyName}"/>
                            <DataGridTextColumn Header="Mass" Binding="{Binding Mass}"/>
                            <DataGridTextColumn Header="Vel X" Binding="{Binding VelX}"/>
                            <DataGridTextColumn Header="Vel Y" Binding="{Binding VelY}"/>
                            <DataGridTextColumn Header="Vel Z" Binding="{Binding VelZ}"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </Expander>

                <!-- Coordinates -->
                <Expander Header="Coordinates &amp; Distances"
                          IsExpanded="True"
                          Margin="0,10,0,0"
                          Background="#E4C9FF">

                    <DataGrid x:Name="dgCoords"
                              AutoGenerateColumns="False"
                              Height="260"
                              Background="#E4C9FF">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Body" Binding="{Binding BodyName}"/>
                            <DataGridTextColumn Header="X" Binding="{Binding X}"/>
                            <DataGridTextColumn Header="Y" Binding="{Binding Y}"/>
                            <DataGridTextColumn Header="D1" Binding="{Binding D1}"/>
                            <DataGridTextColumn Header="D2" Binding="{Binding D2}"/>
                            <DataGridTextColumn Header="Vel Mag" Binding="{Binding VelMagnitude}"/>
                            <DataGridTextColumn Header="Velocity" Binding="{Binding Direction}"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </Expander>

                <!-- Physics Controls -->
                <Expander Header="Physics Controls"
                          IsExpanded="True"
                          Margin="0,10,0,0"
                          Background="#E4C9FF">

                    <StackPanel Margin="8">

                        <TextBlock Text="Gravity Strength:" FontWeight="Bold"/>

                        <DockPanel>
                            <Slider x:Name="sldGravity"
                                    Minimum="0.5"
                                    Maximum="6"
                                    Value="2.5"
                                    Width="180"
                                    ValueChanged="sldGravity_ValueChanged"/>
                            <TextBlock x:Name="txtGravityValue"
                                       Text="2.50"
                                       Margin="8,0"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Text="Simulation Speed:"
                                   FontWeight="Bold"
                                   Margin="0,12,0,4"/>

                        <Slider x:Name="sldSpeed"
                                Minimum="0.2"
                                Maximum="4"
                                Value="1"
                                Width="200"
                                ValueChanged="sldSpeed_ValueChanged"/>

                    </StackPanel>

                </Expander>

            </StackPanel>

        </ScrollViewer>

        <!-- SIMULATION AREA -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="10" Background="#0A0014">
            <render:VisualHost x:Name="RenderSurface"/>
        </Grid>


        <!-- RIGHT PANEL -->
        <StackPanel Grid.Row="1" Grid.Column="2" Margin="10">

            <Expander Header="Body Controls &amp; Presets"
                      IsExpanded="True"
                      Background="#E4C9FF">

                <StackPanel Margin="8">

                    <TextBlock Text="Selected Body:" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbBodySelector"
                              Margin="0,5"
                              SelectionChanged="cmbBodySelector_SelectionChanged"/>

                    <TextBlock Text="Hex Colour:"
                               Margin="0,10,0,2"
                               FontWeight="Bold"/>
                    <TextBox x:Name="txtHexColour"
                             Width="130"
                             TextChanged="txtHexColour_TextChanged"/>

                    <TextBlock Text="Mass of Selected Body:"
                               FontWeight="Bold"/>
                    <Slider x:Name="sldMass"
                            Minimum="0.1"
                            Maximum="50"
                            Value="10"
                            Width="200"
                            Margin="0,2,0,10"
                            ValueChanged="sldMass_ValueChanged"/>

                    <TextBlock Text="Replace with:"
                               Margin="0,15,0,5"
                               FontWeight="Bold"/>

                    <Button Content="Kepler-186f"
                            Margin="2"
                            Click="btnKepler_Click"/>
                    <Button Content="Proxima Centauri b"
                            Margin="2"
                            Click="btnProxima_Click"/>
                    <Button Content="Dwarf Planet (Eris)"
                            Margin="2"
                            Click="btnDwarf_Click"/>

                    <CheckBox x:Name="chkCollisions"
                              Content="Enable Collisions"
                              Margin="0,15,0,0"
                              Checked="chkCollisions_Changed"
                              Unchecked="chkCollisions_Changed"/>

                </StackPanel>

            </Expander>

        </StackPanel>

    </Grid>

</Window>
